FROM python:3.11-slim

WORKDIR /app

# Install docker CLI so the orchestrator can send commands to the sandbox
RUN apt-get update && apt-get install -y docker.io curl && rm -rf /var/lib/apt/lists/*

# Install the Python framework requirements
# (You will create a requirements.txt with langgraph, langchain, openai, mlflow, etc.)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# The code will be mounted via docker-compose volumes, so we don't need to COPY it here.
